<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ApsBrandPrimaryColor">#FF14B9B9</Color>
    <Color x:Key="ApsBrandSoftColor">#FF35C8C5</Color>
    <Color x:Key="ApsBrandMutedColor">#FFA8D2D0</Color>
    <Color x:Key="ApsBrandDeepColor">#FF075E66</Color>
    <Color x:Key="ApsInkDarkColor">#FF061315</Color>
    <Color x:Key="ApsInkColor">#FF10282B</Color>
    <Color x:Key="ApsNightSurfaceColor">#FF0B1E22</Color>
    <Color x:Key="ApsNightSurfaceElevatedColor">#FF102A2F</Color>
    <Color x:Key="ApsPearlColor">#FFF6FCFB</Color>
    <Color x:Key="ApsStrokeDarkColor">#6624565A</Color>
    <Color x:Key="ApsStrokeLightColor">#99A8D2D0</Color>

    <SolidColorBrush x:Key="ApsBrandPrimaryBrush" Color="{StaticResource ApsBrandPrimaryColor}" />
    <SolidColorBrush x:Key="ApsBrandSoftBrush" Color="{StaticResource ApsBrandSoftColor}" />
    <SolidColorBrush x:Key="ApsBrandMutedBrush" Color="{StaticResource ApsBrandMutedColor}" />
    <SolidColorBrush x:Key="ApsBrandDeepBrush" Color="{StaticResource ApsBrandDeepColor}" />
    <SolidColorBrush x:Key="ApsInkDarkBrush" Color="{StaticResource ApsInkDarkColor}" />
    <SolidColorBrush x:Key="ApsInkBrush" Color="{StaticResource ApsInkColor}" />
    <SolidColorBrush x:Key="ApsNightSurfaceBrush" Color="{StaticResource ApsNightSurfaceColor}" />
    <SolidColorBrush x:Key="ApsNightSurfaceElevatedBrush" Color="{StaticResource ApsNightSurfaceElevatedColor}" />
    <SolidColorBrush x:Key="ApsPearlBrush" Color="{StaticResource ApsPearlColor}" />
    <SolidColorBrush x:Key="ApsTextPrimaryBrush" Color="#FFF4FFFD" />
    <SolidColorBrush x:Key="ApsTextSecondaryBrush" Color="#FF9CB8B8" />
    <SolidColorBrush x:Key="ApsTextMutedBrush" Color="#FF60797B" />
    <SolidColorBrush x:Key="ApsGlassDarkBrush" Color="#B30B1E22" />
    <SolidColorBrush x:Key="ApsGlassElevatedBrush" Color="#A6102A2F" />
    <SolidColorBrush x:Key="ApsGlassLightStrokeBrush" Color="{StaticResource ApsStrokeLightColor}" />
    <SolidColorBrush x:Key="ApsGlassDarkStrokeBrush" Color="{StaticResource ApsStrokeDarkColor}" />
    <SolidColorBrush x:Key="ApsIncomingBubbleBrush" Color="#A3102A2F" />
    <SolidColorBrush x:Key="ApsIncomingBubbleStrokeBrush" Color="#29A8D2D0" />
    <SolidColorBrush x:Key="ApsOutgoingTextBrush" Color="#FF073236" />

    <LinearGradientBrush x:Key="ApsAppBackdropBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF061315" Offset="0" />
        <GradientStop Color="#FF0B1E22" Offset="0.48" />
        <GradientStop Color="#FF102A2F" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ApsOutgoingBubbleBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF35C8C5" Offset="0" />
        <GradientStop Color="#FF14B9B9" Offset="0.55" />
        <GradientStop Color="#FF075E66" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ApsSelectedSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3314B9B9" Offset="0" />
        <GradientStop Color="#20102A2F" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ApsInputDockBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#9E102A2F" Offset="0" />
        <GradientStop Color="#80061315" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="RailButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource ApsTextSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="ChromeIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="#1F35C8C5" />
        <Setter Property="BorderBrush" Value="#2424565A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource ApsBrandMutedBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
</ResourceDictionary>

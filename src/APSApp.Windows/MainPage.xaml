                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource ApsBrandDeepBrush}" Text="PDF" />
                            </Border>
                            <Border Grid.Column="2" Height="82" Background="#FF102A2F" BorderBrush="#2EA8D2D0" BorderThickness="1" CornerRadius="14">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource ApsBrandSoftBrush}" Text="GIF" />
                            </Border>
                        </Grid>
                        <Border Padding="14" Background="{StaticResource ApsGlassElevatedBrush}" BorderBrush="{StaticResource ApsGlassDarkStrokeBrush}" BorderThickness="1" CornerRadius="18">
                            <StackPanel Spacing="8">

                            </StackPanel>
                        </Border>
                        <Border Padding="14" Background="{StaticResource ApsGlassElevatedBrush}" BorderBrush="{StaticResource ApsGlassDarkStrokeBrush}" BorderThickness="1" CornerRadius="18">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource ApsTextPrimaryBrush}" Text="Статусы" />
                                <TextBlock Foreground="{StaticResource ApsBrandSoftBrush}" Text="E2EE direct chat" />
                                <TextBlock Foreground="{StaticResource ApsTextSecondaryBrush}" Text="Фэйк-данные • транспорт не подключен • уведомления metadata-only" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Border Height="82" Background="#FFEAF4F3" CornerRadius="14">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource ApsBrandDeepBrush}" Text="IMG" />
